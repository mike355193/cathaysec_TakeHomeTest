<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">
  <targets async="true">
    <target xsi:type="Console" name="console">
      <layout xsi:type="JsonLayout" includeEventProperties="false" maxRecursionLimit="3">
        <attribute name="timestamp" layout="${date:format=o:universalTime=true}" />
        <attribute name="level" layout="${level:uppercase=true}" />
        <attribute name="application" layout="CathaySec.Api" />
        <attribute name="environmentName" layout="${event-properties:item=EnvironmentName}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${event-properties:item=LogMessage}" />
        <attribute name="traceId" layout="${scopeproperty:item=TraceId}" />
        <attribute name="callSite" layout="${event-properties:item=CallSite}" />
        <attribute name="serviceTag" layout="${event-properties:item=ServiceTag}" />
        <attribute name="errorCode" layout="${event-properties:item=ErrorCode}" />
        <attribute name="parameters" layout="${event-properties:item=Parameters:format=@}" encode="false" />
        <attribute name="exception" layout="${exception:format=tostring}" />
      </layout>
    </target>

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/api-${shortdate}.log"
            archiveEvery="Day"
            archiveNumbering="Date"
            archiveDateFormat="yyyyMMdd"
            maxArchiveFiles="30"
            keepFileOpen="false">
      <layout xsi:type="JsonLayout" includeEventProperties="false" maxRecursionLimit="3">
        <attribute name="timestamp" layout="${date:format=o:universalTime=true}" />
        <attribute name="level" layout="${level:uppercase=true}" />
        <attribute name="application" layout="CathaySec.Api" />
        <attribute name="environmentName" layout="${event-properties:item=EnvironmentName}" />
        <attribute name="logger" layout="${logger}" />
        <attribute name="message" layout="${event-properties:item=LogMessage}" />
        <attribute name="traceId" layout="${scopeproperty:item=TraceId}" />
        <attribute name="callSite" layout="${event-properties:item=CallSite}" />
        <attribute name="serviceTag" layout="${event-properties:item=ServiceTag}" />
        <attribute name="errorCode" layout="${event-properties:item=ErrorCode}" />
        <attribute name="parameters" layout="${event-properties:item=Parameters:format=@}" encode="false" />
        <attribute name="exception" layout="${exception:format=tostring}" />
      </layout>
    </target>
  </targets>

  <rules>
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Information" writeTo="console,file" final="true" />
    <logger name="Microsoft.*" maxlevel="Information" final="true" />
    <logger name="Microsoft.*" minlevel="Warning" writeTo="console,file" final="true" />
    <logger name="System.Net.Http.HttpClient.*" maxlevel="Information" final="true" />
    <logger name="System.Net.Http.HttpClient.*" minlevel="Warning" writeTo="console,file" final="true" />
    <logger name="*" minlevel="Information" writeTo="console,file" />
  </rules>
</nlog>
